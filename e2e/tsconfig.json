{
  // The e2e harness runs under Node (Playwright + node-pty) and includes code
  // that executes in the browser (page.evaluate), so it needs both the Node and
  // DOM libs — a different environment from the Ink app in ../src.
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "bun-types"]
  },
  "include": ["."]
}
