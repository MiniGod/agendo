#!/usr/bin/env node
// Fake `tmux` for the e2e harness. It never starts a real tmux server: list
// commands are answered from a JSON state file (FAKE_TMUX_STATE) and every
// invocation is appended to a call log (FAKE_TMUX_LOG) so tests can assert what
// the launcher tried to do. Mutating commands (new-session/new-window) update
// the state so a subsequent reload reflects them, but run nothing.
import fs from "node:fs";

const argv = process.argv.slice(2);
const STATE = process.env.FAKE_TMUX_STATE;
const LOG = process.env.FAKE_TMUX_LOG;

function readState() {
  try {
    const s = JSON.parse(fs.readFileSync(STATE, "utf-8"));
    return {
      sessions: s.sessions ?? [],
      windows: s.windows ?? [],
      panes: s.panes ?? [],
      captures: s.captures ?? {},
    };
  } catch {
    return { sessions: [], windows: [], panes: [], captures: {} };
  }
}
function writeState(s) {
  try { fs.writeFileSync(STATE, JSON.stringify(s, null, 2)); } catch {}
}
function log() {
  if (!LOG) return;
  try { fs.appendFileSync(LOG, JSON.stringify(argv) + "\n"); } catch {}
}

// Value passed to a flag (e.g. flag("-t") -> the arg after -t), or undefined.
function flag(name) {
  const i = argv.indexOf(name);
  return i >= 0 ? argv[i + 1] : undefined;
}
// The -F format template, if present.
function format() {
  return flag("-F");
}
function emit(fmt, record) {
  return fmt
    .replace(/#\{session_name\}/g, record.session ?? "")
    .replace(/#\{window_index\}/g, String(record.index ?? 0))
    .replace(/#\{window_name\}/g, record.window ?? "")
    .replace(/#\{pane_current_path\}/g, record.cwd ?? "")
    .replace(/#\{pane_dead\}/g, record.dead ? "1" : "0")
    // The placeholder conditional `#{?@cl_placeholder,1,0}` → the pane's flag.
    .replace(/#\{\?@cl_placeholder,1,0\}/g, record.placeholder ? "1" : "0");
}

log();
const cmd = argv[0];
const state = readState();

if (argv.includes("-V")) {
  process.stdout.write("tmux 3.4\n");
  process.exit(0);
}

switch (cmd) {
  case "list-sessions": {
    const fmt = format() ?? "#{session_name}";
    process.stdout.write(state.sessions.map((name) => emit(fmt, { session: name })).join("\n"));
    if (state.sessions.length) process.stdout.write("\n");
    process.exit(0);
  }
  case "list-windows": {
    const fmt = format() ?? "#{window_name}";
    process.stdout.write(state.windows.map((w) => emit(fmt, w)).join("\n"));
    if (state.windows.length) process.stdout.write("\n");
    process.exit(0);
  }
  case "list-panes": {
    const fmt = format() ?? "#{pane_current_path}";
    process.stdout.write(state.panes.map((p) => emit(fmt, p)).join("\n"));
    if (state.panes.length) process.stdout.write("\n");
    process.exit(0);
  }
  case "capture-pane": {
    // -p prints to stdout; -t <target> selects the pane. We serve the stored
    // capture text for that target (empty string if none).
    const target = flag("-t");
    const text = state.captures[target] ?? "";
    process.stdout.write(text);
    process.exit(0);
  }
  case "has-session": {
    // Mirror real tmux target resolution so the `=`-exact fix is actually
    // exercised: a bare `-t <name>` resolves by exact, then unique prefix, then
    // fnmatch; a leading `=` pins it to an exact match only. Managed names are
    // prefixes of each other (`cl-pr-5`⊂`cl-pr-50`), so bare resolution would
    // bind the shorter name to the longer live target — the T1 bug.
    let target = flag("-t") ?? "";
    const exactOnly = target.startsWith("=");
    if (exactOnly) target = target.slice(1);
    const names = [...state.sessions, ...state.windows.flatMap((w) => [w.name, w.window].filter(Boolean))];
    const exact = names.includes(target);
    const prefix = !exactOnly && names.some((n) => n.startsWith(target));
    process.exit(exact || prefix ? 0 : 1);
  }
  case "new-session": {
    // ...-s <name> -n <window> -c <cwd> -- <argv...>
    const name = flag("-s");
    const cwd = flag("-c");
    if (name && !state.sessions.includes(name)) {
      state.sessions.push(name);
      state.panes.push({ session: name, window: name, cwd: cwd ?? "" });
      writeState(state);
    }
    process.exit(0);
  }
  case "new-window": {
    const name = flag("-n");
    const cwd = flag("-c");
    if (name) {
      state.windows.push({ session: "launcher-session", index: state.windows.length + 1, name });
      state.panes.push({ session: "launcher-session", window: name, cwd: cwd ?? "" });
      writeState(state);
    }
    process.exit(0);
  }
  // Navigation / config commands: nothing to do, just succeed.
  case "set-window-option":
  case "select-window":
  case "switch-client":
  case "attach-session":
  default:
    process.exit(0);
}
