#!/usr/bin/env node
// Fake `git` for the e2e harness — only the two operations worktree.ts uses are
// implemented, and "worktree add" just creates the target directory so no real
// repository is ever touched. Everything is appended to FAKE_CALL_LOG.
import fs from "node:fs";
import path from "node:path";

const argv = process.argv.slice(2);
const LOG = process.env.FAKE_CALL_LOG;
if (LOG) { try { fs.appendFileSync(LOG, "git " + JSON.stringify(argv) + "\n"); } catch {} }

// Capture then strip a leading `-C <root>`.
let args = argv.slice();
let root = process.cwd();
if (args[0] === "-C") { root = args[1]; args = args.slice(2); }

if (args[0] === "symbolic-ref") {
  // refs/remotes/origin/HEAD --short -> the default branch ref.
  process.stdout.write("origin/main\n");
  process.exit(0);
}

if (args[0] === "remote" && args[1] === "get-url") {
  // The GitHub backend derives a repo slug from origin. We serve a github.com
  // URL owned by `ada` (the fake gh login) named after the repo's directory, so
  // repoRef resolves `ada/<repo>` — the slug the fake gh keys its fixtures on.
  // FAKE_GIT_ORIGIN_HOST selects the origin host so tests can exercise the
  // path-context provider detection (provider.ts detectRepoProvider):
  //   • unset / "github" → a github.com remote (default; forces the GitHub backend)
  //   • "ado"            → an Azure DevOps remote (leaves the default provider)
  //   • "none"           → no origin at all (non-git / no-remote repo)
  const host = process.env.FAKE_GIT_ORIGIN_HOST;
  if (host === "none") { process.stderr.write("error: No such remote 'origin'\n"); process.exit(1); }
  if (host === "ado") { process.stdout.write(`https://dev.azure.com/innovamps/proj/_git/${path.basename(root)}\n`); process.exit(0); }
  process.stdout.write(`https://github.com/ada/${path.basename(root)}.git\n`);
  process.exit(0);
}

if (args[0] === "worktree" && args[1] === "add") {
  // The worktree path is the argument that looks like an absolute path.
  const path = args.slice(2).find((a) => a.startsWith("/"));
  if (path) {
    try { fs.mkdirSync(path, { recursive: true }); } catch {}
  }
  process.exit(0);
}

process.exit(0);
