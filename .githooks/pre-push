#!/usr/bin/env sh
# Backstop: reject a push if any of the commits it would add violate
# Conventional Commits. GitHub.com can't validate messages on a direct push
# (no server-side pre-receive hooks), so this local hook is the guard for
# pushes straight to master. Installed by the "prepare" script.
z40=0000000000000000000000000000000000000000
status=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$z40" ] && continue          # branch deletion — nothing to lint
  if [ "$remote_sha" != "$z40" ]; then
    from="$remote_sha"                            # updating an existing remote branch
  else
    from="$(git merge-base "$local_sha" origin/master 2>/dev/null)"  # new branch
  fi
  if [ -n "$from" ]; then
    bunx commitlint --from "$from" --to "$local_sha" || status=1
  else
    bunx commitlint --from "${local_sha}~1" --to "$local_sha" || status=1
  fi
done
if [ "$status" -ne 0 ]; then
  echo "" >&2
  echo "✖ push rejected: commit message(s) are not Conventional Commits." >&2
  echo "  Amend/rebase the offending commits, then push again." >&2
  exit 1
fi
exit 0
